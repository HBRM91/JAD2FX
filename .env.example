# ─── JAD2FX — Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.
# IMPORTANT: NEVER commit .env.local to git.

# ─── BKAM API (server-side only — direct BAM rate fetching) ─────────────────
# Get your key at: https://api.centralbankofmorocco.ma (subscription portal)
BKAM_FX_KEY=your_bkam_fx_api_key_here

# ─── Resend (email delivery for contact form + PDF reports) ─────────────────
# Sign up at: https://resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@jad2fx.jad2advisory.com
RESEND_TO_EMAIL=contact@jad2advisory.com

# ─── WhatsApp CTA (NEXT_PUBLIC prefix = safe to expose client-side) ─────────
# Format: country code + number, no spaces (e.g. 212600000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=212600000000

# ── ADMIN PASSCODE ────────────────────────────────────────────────────────────
# Required to access the Admin dashboard (/admin route).
# Also used as Authorization: Bearer header for Cloudflare Worker admin endpoints.
ADMIN_PASSCODE=your-strong-passcode-here

# ── CORS PROXY / BKAM API PROXY ───────────────────────────────────────────────
# URL of your deployed Cloudflare Worker (handles BKAM API proxying + market reports).
# See cloudflare/wrangler.toml for deployment instructions.
# Leave empty to use direct API calls (no BKAM proxy, ECB Frankfurter only).
CORS_PROXY_URL=https://your-worker.your-subdomain.workers.dev

# ── PRIMARY LLM (free, fast) ──────────────────────────────────────────────────
# Groq — free tier, Llama 3.3-70B, ~500 req/day free
# Get key: https://console.groq.com → API Keys
# Used for: public RAG chatbot (cost-first primary)
GROQ_API_KEY=gsk_...

# ── OPTIONAL EXTRA FREE TIER ──────────────────────────────────────────────────
# OpenRouter — free models (Llama 3.1 8B, Mistral 7B, Gemma 2 9B)
# Get key: https://openrouter.ai/keys  (free account, no credit card)
# Used for: second fallback after Groq
OPENROUTER_API_KEY=sk-or-v1-...

# ── QUALITY FALLBACK (paid, best reasoning) ───────────────────────────────────
# Google Gemini — gemini-2.5-flash
# Get key: https://aistudio.google.com/apikey  (free quota available)
# Used for: internal Consultant AI (quality-first primary) + fallback for chatbot
GEMINI_API_KEY=AIzaSy...

# ── WEB SEARCH (Cloudflare Worker secret, NOT client-side) ────────────────────
# Tavily API key — used by the Cloudflare Worker for market report generation.
# Set as a Worker secret via: wrangler secret put TAVILY_KEY
# Do NOT put Tavily key here — it must stay in Worker secrets, never in the bundle.
# TAVILY_KEY=tvly-...   (Worker secret only — do not set here)

# ── ROUTING SUMMARY ───────────────────────────────────────────────────────────
# Public chatbot (cost-first):   Groq → OpenRouter → Gemini
# Consultant AI (quality-first): Gemini → Groq → OpenRouter
# Any provider that fails is automatically skipped; no config needed.
#
# Cloudflare Worker secrets (set via wrangler secret put):
#   BKAM_FX_KEY    — BKAM API subscription key for FX (CoursVirement/CoursBBE)
#   BKAM_MONIA_KEY — BKAM API subscription key for BDT (yield curve)
#   TAVILY_KEY     — Tavily search API key for market reports
#   ADMIN_PASSCODE — Same as above (also set as Worker secret for auth)
