# ─── JAD2FX — Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in values. NEVER commit .env to git (it is gitignored).
# Variables are injected at build time by Vite (vite.config.ts → define map).
# Cloudflare Worker secrets are set separately via `wrangler secret put`.

# ── ADMIN PASSCODE ────────────────────────────────────────────────────────────
# Unlocks the Admin dashboard. Also used as Bearer token for Worker admin routes.
ADMIN_PASSCODE=your-strong-passcode-here

# ── CORS PROXY / API PROXY ────────────────────────────────────────────────────
# URL of the deployed Cloudflare Worker (BKAM proxy, LLM proxy, reports, email).
# Get it from: Cloudflare Dashboard → Workers & Pages → your worker → URL
CORS_PROXY_URL=https://jad2fx-yahoo-proxy.YOUR_SUBDOMAIN.workers.dev

# ── CONTACT / LEAD FUNNEL ─────────────────────────────────────────────────────
# WhatsApp number for the contact page CTA (international format, no + or spaces).
# Leave empty to hide the WhatsApp button.
WHATSAPP_NUMBER=212600000000

# ── SEO / ANALYTICS ───────────────────────────────────────────────────────────
# Plausible domain — update index.html data-domain to match once registered at plausible.io
# PLAUSIBLE_DOMAIN=jad2fx.jad2advisory.com   (update index.html manually)

# ── PRIMARY LLM (Groq — free tier) ───────────────────────────────────────────
# https://console.groq.com → API Keys  (Llama 3.3-70B, ~500 req/day free)
GROQ_API_KEY=gsk_...

# ── LLM FALLBACK (Gemini) ─────────────────────────────────────────────────────
# https://aistudio.google.com/apikey  (free quota available)
GEMINI_API_KEY=AIzaSy...

# ── OPTIONAL (OpenRouter) ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...


# ══════════════════════════════════════════════════════════════════════════════
# CLOUDFLARE WORKER SECRETS — set via: wrangler secret put <NAME>
# These MUST NOT be set here — they live in the Worker environment only.
# ══════════════════════════════════════════════════════════════════════════════
#
# BKAM_FX_KEY      — BKAM FX API subscription key (CoursVirement endpoint)
# BKAM_MONIA_KEY   — BKAM MONIA subscription key (BDT yield curve)
# TAVILY_KEY       — Tavily search API key (market report web searches)
# ADMIN_PASSCODE   — Same value as above (Worker uses it to verify admin Bearer token)
# GROQ_API_KEY     — Groq API key (LLM proxy for reports + chatbot, Groq primary)
# GEMINI_API_KEY   — Gemini 2.5 Flash API key (LLM fallback)
# TWELVE_DATA_KEY  — Twelve Data API key (Yahoo Finance failover for EUR cross-rates)
# RESEND_API_KEY   — Resend API key (contact form emails → contact@jad2advisory.com)
# CONTACT_EMAIL    — Destination email for contact leads (e.g. contact@jad2advisory.com)
