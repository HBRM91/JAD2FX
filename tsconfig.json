{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "components",
    "services",
    "context",
    "hooks",
    "utils",
    "scripts",
    "database",
    "locales",
    "vite.config.ts",
    "App.tsx",
    "index.tsx",
    "types.ts",
    "constants.ts"
  ]
}
